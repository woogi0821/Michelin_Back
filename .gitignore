# ============================================================
# Backend - Spring Boot 3 + Gradle + Java 17 + Oracle DB
# ============================================================
 
# Gradle 빌드 캐시 및 산출물
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/
 
# Gradle wrapper (이건 커밋 필요)
gradle/wrapper/gradle-wrapper.properties
 
# Java 컴파일 산출물
*.class
*.jar
*.war
*.ear
*.nar
out/
!**/src/main/**/out/
!**/src/test/**/out/
 
# QueryDSL 자동 생성 Q클래스 (빌드 시 자동 생성됨)
src/main/generated/
 
# MapStruct 생성 파일
target/generated-sources/
 
# 환경 설정 (DB 접속정보, 시크릿 절대 커밋 금지)
application-local.properties
application-prod.properties
application-*.properties
!application.properties
src/main/resources/application-local.properties
src/main/resources/application-prod.properties
 
# IDE - IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/
 
# IDE - Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
 
# IDE - VSCode (Java Extension Pack)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.java-version
 
# Lombok 어노테이션 처리
lombok.config
 
# 로그
logs/
*.log
log/
 
# AWS 배포 (EC2 / ECS / RDS)
.aws/
*.pem
*.key
*.p12
*.pfx
cdk.out/
.aws-sam/
samconfig.toml
.elasticbeanstalk/*
!.elasticbeanstalk/*.cfg.yml
!.elasticbeanstalk/*.global.yml
 
# Docker 로컬 오버라이드
docker-compose.override.yml
 
# OS
.DS_Store
.AppleDouble
Thumbs.db
Desktop.ini
*~
 
# 테스트
test-results/
coverage/
 
# 로컬 SSL 인증서
*.crt
*.cer
